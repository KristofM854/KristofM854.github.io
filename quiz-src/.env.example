# Firebase configuration for the HAB Quiz
# Copy this file to .env and fill in your values.
# .env is NOT committed to git.
# After rotating the Google API key, update VITE_FIREBASE_API_KEY here,
# then rebuild: cd quiz-src && npm run build

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=hab-quiz-ae5a8.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://hab-quiz-ae5a8-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=hab-quiz-ae5a8
VITE_FIREBASE_STORAGE_BUCKET=hab-quiz-ae5a8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=534502811565
VITE_FIREBASE_APP_ID=1:534502811365:web:6f6f114cdff6a54343560c
